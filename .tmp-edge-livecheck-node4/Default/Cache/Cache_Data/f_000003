}

.inspection-shell {
    max-width: 1240px;
}

.inspection-masthead {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: center;
    gap: 18px;
    padding: 18px 28px;
    border-bottom: 1px solid rgba(255, 176, 0, 0.16);
    background: linear-gradient(180deg, rgba(8, 11, 20, 0.98), rgba(8, 10, 18, 0.96));
}

.inspection-masthead__brand,
.inspection-masthead__case,
.inspection-masthead__status,
.inspection-hero__kicker,
.inspection-hero__meta,
.inspection-progress-step span,
.inspection-progress-step strong,
.inspection-card__label,
.inspection-side-panel__label,
.inspection-evidence-panel__title,
.inspection-question-panel__sub,
.inspection-question-panel__hint,
.inspection-attempt-counter {
