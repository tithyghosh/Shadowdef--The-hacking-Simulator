/* ======================
   Puzzle-Specific Styles
   All 5 Puzzle Types
   ====================== */

/* ================
   COMMON PUZZLE ELEMENTS
   ================ */

.puzzle-container {
    width: 100%;
    max-width: 700px;
    max-height: 100%;           
    overflow: hidden;         
}

.puzzle-title {
    color: var(--cyber-pink);
    font-size: 1.5rem;
    margin-bottom: 20px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 2px;
}

.puzzle-instructions {
    background: var(--darker-bg);
    border: 2px solid var(--cyber-blue);
    padding: 15px;
    margin-bottom: 20px;
    color: var(--text-secondary);
    line-height: 1.6;
}

.puzzle-instructions strong {
    color: var(--cyber-blue);
}

.puzzle-actions {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin-top: 20px;
    flex-wrap: wrap;
}

/* ================
   1. PASSWORD CRACKING PUZZLE
   ================ */

.password-puzzle {
    width: 100%;
    max-width: 600px;
}

.password-brief {
    background: var(--darker-bg);
    border: 1px solid rgba(0, 243, 255, 0.35);
    padding: 12px;
    margin-bottom: 16px;
    color: var(--text-secondary);
    font-size: 0.86rem;
    display: grid;
    gap: 8px;
    max-height: 170px;
    overflow-y: auto;
    overflow-x: hidden;
}

.password-brief strong {
    color: var(--cyber-blue);
}

.security-visualizer {
    --viz-risk: 0;
    perspective: 900px;
    background: linear-gradient(145deg, rgba(5, 8, 20, 0.96), rgba(10, 14, 39, 0.92));
    border: 1px solid rgba(0, 243, 255, 0.3);
    margin-bottom: 16px;
    padding: 14px;
}

.security-visualizer-3d {
    border-color: rgba(0, 255, 65, 0.35);
}

.viz-stage {
    transform-style: preserve-3d;
}

.viz-metric {
    margin-top: 10px;
    color: var(--text-secondary);
    font-size: 0.8rem;
}

.visualizer-description {
    margin-top: 8px;
    color: var(--text-muted);
    font-size: 0.78rem;
    line-height: 1.4;
}

.viz-vault {
    width: 110px;
    height: 78px;
    margin: 0 auto;
    border: 2px solid var(--cyber-blue);
    transform: rotateX(18deg) rotateY(calc(var(--viz-risk) * 22deg));
    box-shadow: 0 0 calc(8px + var(--viz-risk) * 18px) rgba(0, 243, 255, 0.45);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}

.security-visualizer[data-state='critical'] .viz-vault {
    border-color: var(--cyber-pink);
}

.viz-shield {
    width: 88px;
    height: 88px;
    margin: 0 auto;
    border: 2px solid var(--cyber-green);
    clip-path: polygon(50% 0%, 92% 20%, 82% 82%, 50% 100%, 18% 82%, 8% 20%);
    transform: translateZ(calc((1 - var(--viz-risk)) * 18px)) scale(calc(1.05 - var(--viz-risk) * 0.2));
    box-shadow: 0 0 14px rgba(0, 255, 65, 0.35);
    transition: all 0.25s ease;
}

.viz-morph {
    display: flex;
    gap: 12px;
    justify-content: center;
    align-items: center;
}

.viz-plain,
.viz-hash {
    border: 1px solid var(--panel-border);
    padding: 8px 10px;
    font-size: 0.75rem;
    transform: translateZ(calc((1 - var(--viz-risk)) * 12px));
    transition: transform 0.25s ease, border-color 0.25s ease;
}

.viz-hash {
    border-color: var(--cyber-green);
}

.viz-arrow {
    color: var(--cyber-blue);
}

.viz-hash-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
}

.viz-hash-block {
    text-align: center;
    padding: 10px;
    border: 1px solid var(--panel-border);
    transform: translateZ(calc((1 - var(--viz-risk)) * 8px));
    transition: all 0.25s ease;
    font-size: 0.75rem;
}

.viz-hash-block.weak {
    border-color: rgba(255, 0, 110, 0.7);
}

.viz-hash-block.strong {
    border-color: rgba(0, 255, 65, 0.7);
}

.viz-salt-pair {
    display: flex;
    justify-content: center;
    gap: 16px;
}

.viz-hash-shape {
    width: 95px;
    text-align: center;
    padding: 8px;
    font-size: 0.72rem;
    border: 1px solid var(--cyber-blue);
    transform: rotateY(calc(var(--viz-risk) * 35deg)) rotateX(8deg);
    transition: transform 0.25s ease, border-color 0.25s ease;
}

.viz-hash-shape:last-child {
    transform: rotateY(calc(var(--viz-risk) * -35deg)) rotateX(8deg);
    border-color: var(--cyber-green);
}

.soc-room {
    display: grid;
    gap: 8px;
}

.viz-log-panel {
    border: 1px solid rgba(0, 243, 255, 0.3);
    padding: 8px 10px;
    font-size: 0.74rem;
    color: var(--text-secondary);
    transform: translateZ(0) rotateX(0);
    transition: transform 0.2s ease, border-color 0.2s ease;
}

.viz-log-panel:hover {
    transform: translateZ(14px) rotateX(4deg);
    border-color: var(--cyber-blue);
}

.viz-enterprise-stack {
    display: grid;
    gap: 6px;
}

.viz-enterprise-controls {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    margin-bottom: 10px;
}

.viz-enterprise-controls label {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.72rem;
    color: var(--text-secondary);
}

.viz-enterprise-controls select {
    background: var(--darker-bg);
    border: 1px solid rgba(0, 243, 255, 0.28);
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 4px 6px;
}

.viz-layer {
    border: 1px solid rgba(0, 243, 255, 0.28);
    padding: 7px 9px;
    font-size: 0.74rem;
    color: var(--text-secondary);
    transform: translateZ(calc((1 - var(--viz-risk)) * 10px));
    transition: transform 0.25s ease, border-color 0.25s ease;
}

.viz-neutral {
    text-align: center;
    color: var(--text-secondary);
    font-size: 0.8rem;
}

.password-display {
    background: var(--darker-bg);
    border: 2px solid var(--cyber-green);
    padding: 20px;
    font-size: 2rem;
    text-align: center;
    letter-spacing: 10px;
    margin-bottom: 30px;
    color: var(--cyber-green);
    font-family: var(--font-mono);
    min-height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.password-hints {
    background: var(--darker-bg);
    border: 2px solid var(--cyber-blue);
    padding: 15px;
    margin-bottom: 20px;
}

.password-hints strong {
    color: var(--cyber-blue);
    display: block;
    margin-bottom: 10px;
}

.hint {
    color: var(--text-secondary);
    margin-bottom: 8px;
    font-size: 0.95rem;
    padding-left: 15px;
}

.hint::before {
    content: '→ ';
    color: var(--cyber-blue);
    margin-right: 5px;
}

.password-input {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-bottom: 20px;
}

.password-options-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin-bottom: 16px;
}

.password-option {
    width: 100%;
    text-align: left;
    background: var(--darker-bg);
    border: 1px solid var(--panel-border);
    color: var(--text-primary);
    font-family: var(--font-mono);
    padding: 10px 12px;
    cursor: pointer;
    transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease;
}

.password-option:hover {
    border-color: var(--cyber-blue);
    transform: translateY(-1px);
}

.password-option.selected {
    border-color: var(--cyber-orange);
    background: rgba(255, 107, 53, 0.12);
    color: var(--cyber-orange);
}

.password-risk-panel {
    margin-bottom: 14px;
}

.password-risk-header {
    display: flex;
    justify-content: space-between;
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 6px;
}

.guess-feedback {
    background: rgba(5, 8, 20, 0.8);
    border: 1px solid rgba(0, 243, 255, 0.28);
    color: var(--text-secondary);
    padding: 10px 12px;
    margin: 0 0 16px 0;
    font-size: 0.82rem;
    line-height: 1.5;
}

.guess-feedback strong {
    color: var(--cyber-blue);
}

.investigation-shell {
    max-width: 1320px;
}

.investigation-masthead {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: center;
    gap: 18px;
    padding: 18px 28px;
    margin-bottom: 18px;
    border: 1px solid rgba(95, 116, 170, 0.2);
    border-radius: 16px;
    background: linear-gradient(180deg, rgba(8, 11, 20, 0.98), rgba(8, 10, 18, 0.96));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
}

.investigation-masthead__brand,
.investigation-masthead__case,
.investigation-masthead__status,
.investigation-case-meta,
.investigation-progress-step__label,
.investigation-progress-step__num,
.investigation-board-stat span,
.investigation-side-chip,
.investigation-question-panel__sub,
.investigation-attempt-counter {
    font-family: var(--font-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
}

.investigation-masthead__brand {
    color: #ffb000;
    font-size: 1.7rem;
    font-weight: 700;
}

.investigation-masthead__case {
    color: rgba(255, 176, 0, 0.82);
    text-align: center;
    font-size: 0.95rem;
}

.investigation-masthead__status {
    color: var(--cyber-green);
    text-align: right;
    font-size: 0.9rem;
}

.investigation-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
    padding: 18px 20px;
    border: 1px solid rgba(95, 116, 170, 0.28);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(14, 17, 28, 0.96), rgba(10, 13, 23, 0.96));
    margin-bottom: 18px;
}

.investigation-header__title {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 18px;
}

.investigation-level-badge {
    min-width: 58px;
    padding: 10px 12px;
    border: 1px solid rgba(255, 0, 110, 0.4);
    border-radius: 8px;
    background: rgba(255, 0, 110, 0.08);
    color: var(--cyber-pink);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.1;
    text-align: center;
    letter-spacing: 1px;
}

.investigation-title {
    margin: 0;
    text-align: left;
    color: var(--cyber-blue);
}

.investigation-subtitle {
    color: var(--text-muted);
    font-size: 0.88rem;
    margin-top: 6px;
    max-width: 620px;
    line-height: 1.6;
}

.investigation-case-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 18px;
    margin-top: 12px;
    color: #7f90b7;
    font-size: 0.72rem;
}

.investigation-header__metrics {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: flex-end;
}

.investigation-metric {
    display: grid;
    gap: 6px;
    text-align: right;
    min-width: 86px;
}

.investigation-metric span {
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 1px;
}

.investigation-metric strong {
    color: var(--cyber-blue);
    font-family: var(--font-mono);
    font-size: 1.85rem;
    line-height: 1;
}

.investigation-hint-strip {
    margin-bottom: 18px;
    padding: 14px 20px;
    border: 1px solid rgba(0, 243, 255, 0.18);
    border-radius: 12px;
    background: linear-gradient(90deg, rgba(0, 243, 255, 0.08), rgba(0, 243, 255, 0.02));
    color: #17c9ff;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    letter-spacing: 0.11em;
}

.investigation-progress-rail {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 22px;
}

.investigation-progress-step {
    display: grid;
    gap: 8px;
    padding: 16px 18px;
    border: 1px solid rgba(95, 116, 170, 0.18);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.02);
    color: #586887;
}

.investigation-progress-step.is-active {
    border-color: rgba(0, 243, 255, 0.3);
    background: linear-gradient(180deg, rgba(0, 243, 255, 0.12), rgba(0, 243, 255, 0.04));
    color: #dfefff;
    box-shadow: 0 0 18px rgba(0, 243, 255, 0.1);
}

.investigation-progress-step__num {
    color: #ffb000;
    font-size: 2rem;
    line-height: 1;
    font-weight: 700;
}

.investigation-progress-step__label {
    font-size: 0.78rem;
}

.investigation-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.18fr) minmax(320px, 380px);
    gap: 18px;
    align-items: start;
}

.investigation-side-stack {
    display: grid;
    gap: 16px;
}

.investigation-panel {
    border: 1px solid rgba(95, 116, 170, 0.26);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(14, 17, 28, 0.96), rgba(9, 12, 22, 0.96));
    overflow: hidden;
}

.investigation-panel__header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
    padding: 14px 18px;
    border-bottom: 1px solid rgba(95, 116, 170, 0.18);
}

.investigation-panel__header strong {
    color: var(--cyber-blue);
    font-family: var(--font-mono);
    font-size: 0.86rem;
    letter-spacing: 1.8px;
}

.investigation-phase-chip {
    padding: 8px 12px;
    border: 1px solid rgba(255, 174, 0, 0.38);
    border-radius: 6px;
    background: rgba(255, 174, 0, 0.12);
    color: #ffae00;
    font-family: var(--font-mono);
    font-size: 0.84rem;
    letter-spacing: 1px;
}

.investigation-board-summary {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    padding: 16px 18px 0;
}

.investigation-board-stat {
    padding: 14px 16px;
    border: 1px solid rgba(95, 116, 170, 0.16);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    display: grid;
    gap: 8px;
}

.investigation-board-stat span {
    color: #7181a7;
    font-size: 0.7rem;
}

.investigation-board-stat strong {
    color: #edf2ff;
    font-family: var(--font-mono);
    font-size: 1.15rem;
}

.investigation-log-list {
    display: grid;
    gap: 12px;
    max-height: 1180px;
    overflow-y: auto;
    padding: 18px;
}

.investigation-log-entry {
    display: grid;
    grid-template-columns: 14px minmax(0, 1fr);
    gap: 12px;
    padding: 4px 0 0;
    border-left: 1px solid transparent;
    cursor: pointer;
}

.investigation-log-entry.is-selected .investigation-log-entry__body {
    border-color: rgba(0, 243, 255, 0.42);
    box-shadow: 0 0 0 1px rgba(0, 243, 255, 0.12);
}

.investigation-log-entry__status {
    width: 12px;
    height: 12px;
    margin-top: 10px;
    border-radius: 50%;
    box-shadow: 0 0 10px currentColor;
}

.investigation-log-entry__status--critical {
    color: #ff3b78;
    background: currentColor;
}

.investigation-log-entry__status--warning {
    color: #ffb000;
    background: currentColor;
}

.investigation-log-entry__status--safe {
    color: var(--cyber-green);
    background: currentColor;
}

.investigation-log-entry__body {
    padding: 12px 0 14px;
    border-bottom: 1px solid rgba(95, 116, 170, 0.14);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.investigation-log-entry__meta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.84rem;
    margin-bottom: 6px;
}

.investigation-log-entry__title {
    color: #d5dbea;
    font-size: 0.98rem;
    line-height: 1.4;
}

.investigation-log-entry__subtitle {
    color: #7e8eb6;
    font-size: 0.82rem;
    margin-top: 4px;
}

.investigation-log-entry__actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 12px;
}

.investigation-action-btn {
    min-width: 92px;
    border: 1px solid rgba(196, 205, 228, 0.28);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.02);
    color: #eef2ff;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 1px;
    padding: 10px 14px;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
}

.investigation-action-btn:hover {
    transform: translateY(-1px);
    border-color: rgba(255, 255, 255, 0.42);
}

.investigation-action-btn.is-flagged {
    border-color: rgba(255, 0, 110, 0.44);
    background: rgba(255, 0, 110, 0.12);
    color: var(--cyber-pink);
}

.investigation-profile {
    padding: 18px;
}

.investigation-profile__name {
    color: #eef2ff;
    font-size: 1.15rem;
    font-weight: 700;
}

.investigation-profile__role {
    color: #8d9ec3;
    font-family: var(--font-mono);
    font-size: 0.86rem;
    margin-top: 4px;
}

.investigation-mini-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 18px;
}

.investigation-mini-card {
    display: grid;
    gap: 8px;
    padding: 14px;
    border: 1px solid rgba(95, 116, 170, 0.18);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.03);
}

.investigation-mini-card__label {
    color: #7888af;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 1px;
}

.investigation-mini-card__value {
    color: #d8deee;
    font-size: 0.98rem;
    line-height: 1.3;
}

.investigation-policy {
    padding: 14px 18px;
}

.investigation-policy-row {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(95, 116, 170, 0.12);
    color: #94a5cb;
    font-family: var(--font-mono);
    font-size: 0.84rem;
}

.investigation-policy-row:last-child {
    border-bottom: 0;
}

.investigation-policy-row strong.is-bad {
    color: var(--cyber-pink);
}

.investigation-policy-row strong.is-good {
    color: var(--cyber-orange);
}

.investigation-side-chip {
    color: #7fd5ff;
    font-size: 0.68rem;
}

.investigation-selected-entry {
    min-height: 112px;
    padding: 18px;
    color: #91a1c8;
}

.investigation-selected-entry__empty {
    color: #5d6d95;
    font-family: var(--font-mono);
    font-size: 0.9rem;
}

.investigation-selected-entry__meta {
    color: #6f7fa9;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin-bottom: 8px;
}

.investigation-selected-entry__title {
    color: #edf2ff;
    font-size: 1rem;
    margin-bottom: 6px;
}

.investigation-selected-entry__subtitle {
    color: #8192b8;
    margin-bottom: 12px;
}

.investigation-selected-entry__body {
    color: #94a5cb;
    line-height: 1.55;
}

.investigation-selected-entry__flag {
    margin-top: 14px;
    color: #6f7fa9;
    font-family: var(--font-mono);
    font-size: 0.78rem;
}

.investigation-selected-entry__flag.is-flagged {
    color: var(--cyber-pink);
}

.investigation-question-panel {
    border: 1px solid rgba(95, 116, 170, 0.26);
    border-radius: 18px;
    background: linear-gradient(180deg, rgba(13, 18, 31, 0.98), rgba(8, 12, 24, 0.98));
    margin-top: 18px;
    overflow: hidden;
    box-shadow: 0 18px 44px rgba(0, 0, 0, 0.24);
}

.investigation-question-panel__title {
    padding: 20px 20px 10px;
    color: #dfe7f7;
    font-size: 1.14rem;
    font-weight: 700;
    line-height: 1.5;
}

.investigation-question-panel__sub {
    padding: 0 20px 16px;
    color: #7383aa;
    font-size: 0.74rem;
    line-height: 1.5;
}

.investigation-question-panel__meta {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    padding: 0 20px 18px;
    border-bottom: 1px solid rgba(95, 116, 170, 0.16);
}

.investigation-question-stat {
    display: grid;
    gap: 8px;
    padding: 14px 16px;
    border: 1px solid rgba(95, 116, 170, 0.18);
    border-radius: 14px;
    background: linear-gradient(180deg, rgba(0, 243, 255, 0.05), rgba(255, 255, 255, 0.02));
}

.investigation-question-stat span {
    color: #7383aa;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
}

.investigation-question-stat strong {
    color: #eef4ff;
    font-size: 0.98rem;
    line-height: 1.45;
}

.investigation-choice-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    padding: 18px 20px;
}

