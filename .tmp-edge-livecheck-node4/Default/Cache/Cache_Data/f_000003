    border-top: 1px solid rgba(95, 116, 170, 0.16);
}

.investigation-question-panel__hint {
    color: #7383aa;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.5;
}

.investigation-feedback {
    margin-top: 18px;
